{
  "App": {
    "Name": "Notifications Worker",
    "Service": "notifications-worker",
    "Version": "v1"
  },
  "ConnectionStrings": {
    "NotificationsDB": "Fetch from azure key vault",
    "EventBus": "Fetched from azure key vault",
    "Redis": "Fetched from azure key vault"
  },
  "MinWorkerThreads": 512,
  "MinIOThreads": 512,
  "Logger": {
    "Level": "information",
    "ExcludePaths": [ "/", "/ping", "/metrics" ],
    "ExcludeProperties": [
      "api_key",
      "access_key",
      "ApiKey",
      "ApiSecret",
      "ClientId",
      "ClientSecret",
      "ConnectionString",
      "Password",
      "Email",
      "Login",
      "Secret",
      "Token"
    ],
    "Console": {
      "Enabled": true
    },
    "File": {
      "Enabled": true,
      "Path": "../../logs/logs.txt",
      "Interval": "day"
    },
    "AppInsights": {
      "Enabled": true
    },
    "Tags": {}
  },
  "Hangfire": {
    "Enabled": true,
    "ConnectionStringName": "NotificationsDB",
    "UseServer": true,
    "UseDashboard": true,
    "IsLocalEnvironment": false
  },
  "Redis": {
    "ConnectionStringName": "Redis",
    "Instance": "ns:"
  },
  "Prometheus": {
    "Enabled": true,
    "Endpoint": "/metrics"
  },
  "ServiceBus": {
    "Enabled": true,
    "ConnectionStringName": "EventBus",
    "TopicName": "keka_event_bus",
    "SubscriptionName": "keka_notifications",
    "EnableConsumerHandler": true,
    "MaxConcurrentCalls": 50
  },
  "TableStorage": {
    "Enabled": true,
    "ConnectionStringName": "NotificationsTableStorage"
  },
  "BlobStorage": {
    "Enabled": true,
    "ConnectionStringName": "NotificationsTableStorage"
  },
  "Vault": {
    "Enabled": true,
    "TenantId": "79082f94-5bea-4f6d-ae0d-b65ed3047edd",
    "VaultUri": "https://kv-keka-local-cin.vault.azure.net/"
  },
  "HttpClient": {
    "Retries": 3,
    "Services": {
      "employee": "Fetched from Azure key vault"
    }
  },
  "kekaOAuth": {
    "Authority": "Fetched from azure key vault",
    "ClientId": "Fetched from azure key vault",
    "ClientSecret": "Fetched from azure key vault",
    "Scope": "Fetched from azure key vault"
  },
  "ApplicationInsights": {
    "Enabled": true,
    "ConnectionString": "InstrumentationKey=d8c7525c-7d80-4ea0-a468-92d02f7451bc;IngestionEndpoint=https://centralindia-0.in.applicationinsights.azure.com/;LiveEndpoint=https://centralindia.livediagnostics.monitor.azure.com/"
  },
  "AllowedHosts": "*"
}
